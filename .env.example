NODE_ENV=development

# -----------------------------------------------------------------------------
# Web
# Required. Frontend calls this API base URL.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# API
# Required.
# -----------------------------------------------------------------------------
PORT=3001
WEB_ORIGIN=http://localhost:3000
INTERNAL_API_KEY=

# -----------------------------------------------------------------------------
# Database / Queue
# Required.
# Use your local PostgreSQL user by default.
# If you start PostgreSQL via docker-compose in this repo, you can switch to:
# postgresql://postgres:postgres@localhost:5432/gitdian?schema=public
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://<YOUR_POSTGRES_USER>@localhost:5432/gitdian?schema=public
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# GitHub
# Prefer GITHUB_TOKENS for backfill / radar workloads.
# Multiple tokens are comma-separated and will be trimmed + deduplicated.
# If GITHUB_TOKENS is empty, the app falls back to GITHUB_TOKEN.
# If both are empty, the app runs in anonymous mode (not recommended).
# -----------------------------------------------------------------------------
GITHUB_TOKENS=
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_SEARCH_MAX_CONCURRENCY=8
GITHUB_SEARCH_MIN_CONCURRENCY=4
GITHUB_SEARCH_ADJUST_INTERVAL_MS=60000
GITHUB_SEARCH_SCALE_UP_STEP=2
GITHUB_SEARCH_SCALE_DOWN_STEP=2
GITHUB_BACKFILL_CONCURRENCY=1

# -----------------------------------------------------------------------------
# Local AI (Required for fully local demo)
# These defaults match the verified local oMLX setup used by this project.
# OMLX_API_KEY is required only when your local oMLX server has auth enabled.
# -----------------------------------------------------------------------------
OMLX_BASE_URL=http://127.0.0.1:8000/v1
OMLX_MODEL=Qwen3.5-122B-A10B-MLX-9bit-finetuned
OMLX_API_KEY=
OMLX_TIMEOUT_MS_SNAPSHOT=120000
OMLX_TIMEOUT_MS_DEEP=180000
OMLX_TIMEOUT_MS_IDEA_EXTRACT=240000
USE_HEAVY_MODEL_FOR_SNAPSHOT=true

# -----------------------------------------------------------------------------
# AI routing
# Current default mode runs through the API / OpenAI primary chain.
# -----------------------------------------------------------------------------
AI_DEFAULT_PROVIDER=openai
AI_FALLBACK_PROVIDER=openai
AI_ENABLE_FALLBACK=false
IDEA_SNAPSHOT_CONCURRENCY=4
DEEP_ANALYSIS_CONCURRENCY=6
PRIORITIZE_DEEP_ANALYSIS=true
IDEA_EXTRACT_MAX_INFLIGHT=2
QUEUE_JOB_HEARTBEAT_MS=15000
QUEUE_DB_HEARTBEAT_MS=60000
QUEUE_RUNTIME_HEARTBEAT_MS=30000
QUEUE_LOCK_DURATION_MS=600000
QUEUE_STALLED_INTERVAL_MS=60000
QUEUE_MAX_STALLED_COUNT=3
COLD_TOOL_COLLECT_CONCURRENCY=2
ENABLE_COLD_TOOL_COLLECT_WORKER=false
ENABLE_COLD_TOOL_COLLECT_SCHEDULER=true
COLD_TOOL_COLLECT_INTERVAL_MS=900000
ENABLE_COLD_TOOL_COLLECT_WATCHDOG=true
COLD_TOOL_WATCHDOG_INTERVAL_MS=60000
COLD_TOOL_STALE_RUNTIME_MINUTES=10
ENABLE_ANALYSIS_SINGLE_WATCHDOG=true
ANALYSIS_SINGLE_WATCHDOG_INTERVAL_MS=60000
ANALYSIS_SINGLE_STALE_MINUTES=30
ANALYSIS_SINGLE_STALE_RECOVERY_LIMIT=48
COLD_TOOL_SCHEDULER_FORCE_REFRESH=false
COLD_TOOL_QUERY_CONCURRENCY=6
COLD_TOOL_GITHUB_FETCH_ENRICH_CONCURRENCY=3
COLD_TOOL_EXTERNAL_QUERY_CONCURRENCY=3
COLD_TOOL_EXTERNAL_IMPORT_CONCURRENCY=3
COLD_TOOL_EXTERNAL_PER_QUERY_LIMIT=6
COLD_TOOL_EXTERNAL_SKIP_SYNC_RECENT_HOURS=72
COLD_TOOL_HYDRATE_CONCURRENCY=4
COLD_TOOL_HYDRATE_REFRESH_HOURS=24
COLD_TOOL_QUERIES_PER_RUN=36
COLD_TOOL_PER_QUERY_LIMIT=8
COLD_TOOL_LOOKBACK_DAYS=540
COLD_TOOL_INCLUDE_ANY_LANGUAGE=true
COLD_TOOL_CORE_LANGUAGES=TypeScript,JavaScript,Python,Go
COLD_TOOL_SECONDARY_LANGUAGES=Java,Rust,C#,PHP
COLD_TOOL_TAIL_LANGUAGES=Kotlin,Swift,Ruby,Dart,Shell,Elixir
COLD_TOOL_PROBLEM_TERMS=monitor,diff,sync,dedupe,ocr,proxy,scraper,wallet,gateway
COLD_TOOL_ACTION_TERMS=generate,convert,lint,self-host,visualize,orchestrate,backup
COLD_TOOL_FORM_TERMS=cli,sdk,api,agent,worker,plugin,daemon,self-hosted
COLD_TOOL_TARGET_TERMS=s3,postgresql,telegram,chrome,kubernetes
COLD_TOOL_PROBLEM_BUCKET_SIZE=6
COLD_TOOL_ACTION_BUCKET_SIZE=2
COLD_TOOL_FORM_BUCKET_SIZE=2
COLD_TOOL_TARGET_BUCKET_SIZE=2
COLD_TOOL_DISCOVERY_MODEL=gpt-5.4

# -----------------------------------------------------------------------------
# Primary API / OpenAI analysis chain
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_API_KEYS=
OPENAI_MODEL=
OPENAI_BASE_URL=
OPENAI_MODEL_CANDIDATES=
OPENAI_MAX_CONCURRENCY=6
OPENAI_RETRY_MAX=4
OPENAI_CONCURRENCY_RECOVERY_SUCCESS_COUNT=8
OPENAI_CONCURRENCY_SHRINK_FACTOR=0.5

# -----------------------------------------------------------------------------
# Cold-tool OpenAI lane
# Optional dedicated key/concurrency for cold-tool discovery so it does not
# consume the primary analysis lane.
# -----------------------------------------------------------------------------
COLD_TOOL_OPENAI_API_KEY=
COLD_TOOL_OPENAI_API_KEYS=
COLD_TOOL_OPENAI_BASE_URL=
COLD_TOOL_OPENAI_MODEL=
COLD_TOOL_OPENAI_MODEL_CANDIDATES=
COLD_TOOL_OPENAI_LIGHT_MODEL=
COLD_TOOL_OPENAI_HEAVY_MODEL=
COLD_TOOL_SNAPSHOT_MODEL=
COLD_TOOL_COMPLETENESS_MODEL=
COLD_TOOL_IDEA_FIT_MODEL=
COLD_TOOL_IDEA_EXTRACT_MODEL=
COLD_TOOL_OPENAI_MAX_CONCURRENCY=2
COLD_TOOL_OPENAI_CONCURRENCY_RECOVERY_SUCCESS_COUNT=8
COLD_TOOL_OPENAI_LANE_KEY=cold_tool

# -----------------------------------------------------------------------------
# Historical Claude compatibility layer
# Runtime is disabled by default. The primary API chain handles analysis work.
# -----------------------------------------------------------------------------
CLAUDE_RUNTIME_RETIRED=true
CLAUDE_ENABLED=false
CLAUDE_API_BASE_URL=
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_TIMEOUT_MS=120000
CLAUDE_RETRY_MAX=2
CLAUDE_MAX_TOKENS=1200
CLAUDE_REVIEW_DAILY_LIMIT=50
CLAUDE_REVIEW_MAX_PER_RUN=10
CLAUDE_REVIEW_ONLY_FOR_TOP_CANDIDATES=true

# -----------------------------------------------------------------------------
# Queue / Worker
# Keep false for the API process. Run the worker in a separate process.
# -----------------------------------------------------------------------------
ENABLE_QUEUE_WORKERS=false

# -----------------------------------------------------------------------------
# Daily Autonomous Radar
# Enable in the worker process only when new GitHub intake is open.
# For frozen stock cleanup / historical repair mode, keep this off.
# -----------------------------------------------------------------------------
ENABLE_CONTINUOUS_RADAR=false
RADAR_BOOTSTRAP_DAYS=30
RADAR_LIVE_LOOKBACK_DAYS=1
RADAR_SCHEDULER_INTERVAL_MS=4000
RADAR_BOOTSTRAP_FAST_START=true
SNAPSHOT_QUEUE_LOW_WATERMARK=6
SNAPSHOT_QUEUE_HIGH_WATERMARK=24
DEEP_QUEUE_LOW_WATERMARK=2
DEEP_QUEUE_HIGH_WATERMARK=8
SNAPSHOT_REFRESH_DAYS=14
DEEP_ANALYSIS_REFRESH_DAYS=30
CONTINUOUS_DEFAULT_LANGUAGE=TypeScript
CONTINUOUS_DEFAULT_STAR_MIN=1
CONTINUOUS_DEFAULT_PER_WINDOW_LIMIT=10
CONTINUOUS_DEFAULT_TARGET_CATEGORIES=tools,ai,data,infra
RADAR_KEYWORD_MODE_ENABLED=false
RADAR_KEYWORD_STRATEGY=balanced
RADAR_KEYWORD_LOOKBACK_DAYS=14
RADAR_KEYWORD_PER_QUERY_LIMIT=10
RADAR_KEYWORD_SEARCH_CONCURRENCY=2
RADAR_KEYWORDS_TOOLS=workflow,automation,productivity,devtools,cli,browser extension,mcp
RADAR_KEYWORDS_AI=agent,ai coding,rag,search,assistant,openai,langchain
RADAR_KEYWORDS_DATA=data pipeline,etl,scraping,analytics,warehouse
RADAR_KEYWORDS_INFRA=auth,observability,deployment,storage,api gateway,security

# -----------------------------------------------------------------------------
# Long-running maintenance
# Lightweight unattended hardening for logs, retention, warnings, and summaries.
# -----------------------------------------------------------------------------
RADAR_MAINTENANCE_INTERVAL_MS=600000
LOG_ROTATE_MAX_BYTES=20971520
LOG_ROTATE_KEEP_FILES=14
FAILED_JOBLOG_RETENTION_DAYS=14
SUCCESS_JOBLOG_RETENTION_DAYS=45
ANALYSIS_RAW_RESPONSE_RETENTION_DAYS=14

# -----------------------------------------------------------------------------
# Daily Telegram report
# Uses the existing Daily Summary to send one lightweight创业机会日报 per day.
# Keep disabled unless bot token + chat id are configured.
# -----------------------------------------------------------------------------
ENABLE_DAILY_TELEGRAM_REPORT=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DAILY_TELEGRAM_REPORT_HOUR=21
DAILY_TELEGRAM_REPORT_MINUTE=0
DAILY_TELEGRAM_TIMEZONE=Asia/Shanghai
