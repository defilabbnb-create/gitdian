{
  "name": "gitdian",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:worker": "pnpm --filter api start:worker",
    "build": "pnpm -r --if-present run build",
    "health:daily": "pnpm --filter api health:daily",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "format": "prettier --write .",
    "verify:production": "node scripts/verify-production.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "playwright": "^1.58.2",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  }
}
