{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:worker": "ENABLE_QUEUE_WORKERS=true node dist/worker.js",
    "export:training-knowledge": "node dist/scripts/export-training-knowledge.js",
    "recover:historical-data": "node dist/scripts/run-historical-data-recovery.js",
    "report:task-analysis-completion": "node dist/scripts/report-task-analysis-completion.js",
    "health:daily": "node dist/scripts/health/daily-health-check.js",
    "scheduler:adaptive": "node dist/scripts/health/run-adaptive-scheduler.js",
    "rebuild:cached-rankings": "node dist/scripts/rebuild-repository-cached-rankings.js",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && node --test test/*.test.js"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.11",
    "@nestjs/core": "^11.0.11",
    "@nestjs/platform-express": "^11.0.11",
    "@prisma/client": "^6.17.1",
    "bullmq": "^5.71.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "prisma": "^6.17.1",
    "typescript": "^5.8.2"
  }
}
