{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare:shared-vendor": "node ../../scripts/sync-web-shared-vendor.mjs",
    "predev": "pnpm run prepare:shared-vendor",
    "dev": "next dev -p 3000",
    "prebuild": "pnpm run prepare:shared-vendor",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "pretypecheck": "pnpm run prepare:shared-vendor",
    "typecheck": "tsc --noEmit",
    "pretest:unit": "pnpm run prepare:shared-vendor",
    "test:unit": "tsx --tsconfig tsconfig.unit.json --test test/**/*.test.ts test/**/*.test.tsx"
  },
  "dependencies": {
    "next": "^15.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.2.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0"
  }
}
